{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "nextjs"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "api/index.py"
        }
    },
    "rewrites": [
        {
            "source": "/api/backend(/.*)?",
            "destination": "/_/backend$1"
        }
    ]
}
